#!/usr/bin/env sh
set -eu

commit_msg_file="${1:-}"

fail() {
  printf 'commit-msg: %s\n' "$1" >&2
  exit 1
}

[ -n "$commit_msg_file" ] || fail "missing commit message path"
[ -f "$commit_msg_file" ] || fail "commit message file not found: $commit_msg_file"

first_line=$(sed -n '1p' "$commit_msg_file" | tr -d '\r')

case "$first_line" in
  Merge\ *|Revert\ *|fixup!\ *|squash!\ *)
    exit 0
    ;;
esac

types='feat|fix|docs|style|refactor|chore|build|ci|test|perf|revert'
scopes='arch|assets|audio|chezmoi|docs|fonts|git|hypr|hyprpaper|kitty|mako|portal|rice|screenshots|security|shell|superpowers|theme|wallpaper|waybar|wofi'

pattern="^(${types})\\((${scopes})\\)!?: .+[^.]$"

if printf '%s\n' "$first_line" | grep -Eq "$pattern"; then
  :
else
  cat >&2 <<EOF
Invalid commit message:
  $first_line

Expected:
  type(scope): subject
  type(scope)!: subject

Allowed types:
  feat, fix, docs, style, refactor, chore, build, ci, test, perf, revert

Allowed scopes:
  arch, assets, audio, chezmoi, docs, fonts, git, hypr, hyprpaper, kitty,
  mako, portal, rice, screenshots, security, shell, superpowers, theme,
  wallpaper, waybar, wofi

Examples:
  feat(hypr): add workspace navigation bindings
  docs(superpowers): document screenshot workflow
  chore(chezmoi): add kitty config to source state
EOF
  exit 1
fi

ai_identity='(codex|claude|chatgpt|copilot|gemini|openai[[:space:]-]?codex|anthropic[[:space:]-]?claude)'

if grep -Eiq "^[[:space:]]*co-authored-by:[[:space:]]*.*$ai_identity" "$commit_msg_file"; then
  fail "AI tools must not be credited as coauthors"
fi

if grep -Eiq '^[[:space:]]*([[:alnum:]_-]+-)?(ai|llm|assistant|generated)([[:alnum:] _-]*)?:[[:space:]]*.+' "$commit_msg_file"; then
  fail "AI-related commit trailers are not allowed"
fi

if grep -Eiq "(generated|created|written|assisted)[[:space:]-]+(with|by)[[:space:]].*$ai_identity" "$commit_msg_file"; then
  fail "AI-generated commit footers are not allowed"
fi
