; cava — poolside palette (A Bigger Splash).
; Visualises the monitor of the default PipeWire sink, so it reacts to anything
; playing through your speakers (ncspot, mpv, a browser tab, ...).

[general]
mode = normal
framerate = 60
autosens = 1
overshoot = 0
sensitivity = 100
; bars = 0 lets cava auto-fit the bar count to the window width.
bars = 0
bar_width = 2
bar_spacing = 1
lower_cutoff_freq = 50
higher_cutoff_freq = 10000

[input]
method = pipewire
source = auto

[output]
method = ncurses
channels = stereo
mono_option = average

; Bottom-to-top gradient: pool blue rising to a terracotta "splash" at the peaks.
[color]
gradient = 1
gradient_count = 6
gradient_color_1 = '#3d7590'
gradient_color_2 = '#5a9ec2'
gradient_color_3 = '#54b5c2'
gradient_color_4 = '#cf9a24'
gradient_color_5 = '#d46a4e'
gradient_color_6 = '#c25438'

[smoothing]
noise_reduction = 0.45
